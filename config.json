  "HERO_CARDS": "\n      <div class=\"hero-glass\">\n        <div class=\"hg-icon\"><i data-lucide=\"utensils\"></i></div>\n        <h3>Tuoreet raaka-aineet</h3>\n        <p>Valmistamme kaiken tuoreista, laadukkaista raaka-aineista paivittain.</p>\n      </div>\n\n      <div class=\"hero-glass\">\n        <div class=\"hg-icon\"><i data-lucide=\"heart\"></i></div>\n        <h3>Tehty rakkaudella</h3>\n        <p>Jokainen annos on valmistettu intohimolla ja ammattitaidolla.</p>\n      </div>",
  "STATS_HTML": "\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"500\" data-suffix=\"+\">500+</div>\n      <div class=\"stat-label\">Tyytyvaista asiakasta</div>\n    </div>\n\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"10\" data-suffix=\"+\">10+</div>\n      <div class=\"stat-label\">Vuotta kokemusta</div>\n    </div>\n\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"5\" data-suffix=\"/5\">5/5</div>\n      <div class=\"stat-label\">Asiakastyytyvaisyys</div>\n    </div>\n\n    <div class=\"stat reveal\">\n      <div class=\"stat-num counter\" data-target=\"98\" data-suffix=\"%\">98%</div>\n      <div class=\"stat-label\">Suosittelee</div>\n    </div>",
  "SERVICES_HTML": "\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1476224203421-9ac39bcb3327?w=600&h=400&fit=crop&q=80\" alt=\"Lounas\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"coffee\"></i></div>\n        <div class=\"srv-name\">Lounas</div>\n        <div class=\"srv-desc\">Monipuolinen ja tuore lounasvalikoimamme vaihtuu paivittain. Lounas sisaltaa salaattibuffetin ja paivan paaruoan.</div>\n        <div class=\"srv-price\">12-16 eur</div>\n      </div>\n    </div>\n\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1544025162-d76694265947?w=600&h=400&fit=crop&q=80\" alt=\"A la carte\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"chef-hat\"></i></div>\n        <div class=\"srv-name\">A la carte</div>\n        <div class=\"srv-desc\">Laaja valikoima huolellisesti valmistettuja annoksia parhaista raaka-aineista. Soveltuu niin arkeen kuin juhlaankin.</div>\n        <div class=\"srv-price\">18-32 eur</div>\n      </div>\n    </div>\n\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1559339352-11d035aa65de?w=600&h=400&fit=crop&q=80\" alt=\"Tilaisuudet\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"users\"></i></div>\n        <div class=\"srv-name\">Tilaisuudet</div>\n        <div class=\"srv-desc\">Jarjestamme yksityistilaisuuksia, syntymapaiviaai ja yritystapahtumia. Raataloimme menun toiveidenne mukaan.</div>\n        \n      </div>\n    </div>\n\n    <div class=\"srv-card reveal\">\n      <div class=\"srv-card-img\"><img src=\"https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=600&h=400&fit=crop&q=80\" alt=\"Nouto ja toimitus\" loading=\"lazy\"></div>\n      <div class=\"srv-card-body\">\n        <div class=\"srv-icon-wrap\"><i data-lucide=\"truck\"></i></div>\n        <div class=\"srv-name\">Nouto ja toimitus</div>\n        <div class=\"srv-desc\">Tilaa suosikkiruokasi kotiin tai nouda ravintolastamme. Nopea ja helppo tilaus puhelimitse.</div>\n        \n      </div>\n    </div>",
  "REVIEWS_HTML": "\n    <div class=\"rev-card reveal\">\n      <div class=\"rev-stars\"><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div>\n      <div class=\"rev-text\">\"Erinomainen ruoka ja lamminhenkinen palvelu. Suosittelen lampimasti kaikille!\"</div>\n      <div class=\"rev-author\">\n        <div class=\"rev-avatar\">M</div>\n        <div class=\"rev-info\"><div class=\"rev-name\">Maria K.</div><div class=\"rev-role\">Asiakas</div></div>\n      </div>\n    </div>\n\n    <div class=\"rev-card reveal\">\n      <div class=\"rev-stars\"><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div>\n      <div class=\"rev-text\">\"Parasta lounasta kaupungissa. Tulemme aina uudestaan perheen kanssa.\"</div>\n      <div class=\"rev-author\">\n        <div class=\"rev-avatar\">J</div>\n        <div class=\"rev-info\"><div class=\"rev-name\">Jukka L.</div><div class=\"rev-role\">Asiakas</div></div>\n      </div>\n    </div>\n\n    <div class=\"rev-card reveal\">\n      <div class=\"rev-stars\"><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><svg class=\"rev-star\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div>\n      <div class=\"rev-text\">\"Annokset ovat runsaita ja maukkaita. Hinnat ovat kohtuullisia laadun huomioon ottaen.\"</div>\n      <div class=\"rev-author\">\n        <div class=\"rev-avatar\">A</div>\n        <div class=\"rev-info\"><div class=\"rev-name\">Anna S.</div><div class=\"rev-role\">Asiakas</div></div>\n      </div>\n    </div>",
